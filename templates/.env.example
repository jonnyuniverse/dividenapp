# ─── DiviDen Command Center Environment Variables ───────────────────────────

# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://your_user:your_password@localhost:5432/dividen"

# NextAuth.js
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider API Keys (add via Settings page or here)
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# ─── Optional ────────────────────────────────────────────────────────────────

# Server port (default: 3000)
# PORT=3000

# Node environment
NODE_ENV="development"
