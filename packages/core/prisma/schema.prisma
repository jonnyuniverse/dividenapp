// DiviDen Command Center - Database Schema
// Supports PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Authentication & Users ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          String    @default("admin")
  mode          String    @default("cockpit") // "cockpit" | "chief_of_staff"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  kanbanCards   KanbanCard[]
  chatMessages  ChatMessage[]
  contacts      Contact[]
  memoryItems   MemoryItem[]
  userLearnings UserLearning[]

  @@map("users")
}

// ─── Kanban Board ──────────────────────────────────────────────────────────────

model KanbanCard {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      String          @default("leads") // pipeline stage
  priority    String          @default("medium")   // "low" | "medium" | "high" | "urgent"
  assignee    String          @default("human") // "human" | "agent"
  dueDate     DateTime?
  order       Int             @default(0)
  userId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklist   ChecklistItem[]
  contacts    CardContact[]

  @@map("kanban_cards")
}

model ChecklistItem {
  id        String     @id @default(cuid())
  text      String
  completed Boolean    @default(false)
  order     Int        @default(0)
  cardId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  card      KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// ─── Queue System ──────────────────────────────────────────────────────────────

model QueueItem {
  id          String   @id @default(cuid())
  type        String   // "task" | "notification" | "reminder" | "agent_suggestion"
  title       String
  description String?
  priority    String   @default("medium")  // "low" | "medium" | "high" | "urgent"
  status      String   @default("ready")   // "ready" | "in_progress" | "done_today" | "blocked"
  source      String?  // "user" | "agent" | "system"
  userId      String?
  metadata    String?  // JSON string for flexible data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("queue_items")
}

// ─── Chat & Agent Communication ────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" | "assistant" | "system"
  content   String
  userId    String?
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("chat_messages")
}

model AgentMessage {
  id        String   @id @default(cuid())
  agentName String
  type      String   // "status_update" | "suggestion" | "alert" | "completion"
  content   String
  priority  String   @default("normal")
  read      Boolean  @default(false)
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  @@map("agent_messages")
}

// ─── CRM / Contacts ───────────────────────────────────────────────────────────

model Contact {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  role         String?
  notes        String?
  tags         String?       // Comma-separated tags
  source       String?       // "manual" | "chat" | "enriched"
  enrichedData String?       // JSON string for enrichment data
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards        CardContact[]

  @@map("contacts")
}

model CardContact {
  id        String     @id @default(cuid())
  cardId    String
  contactId String
  role      String?    // Contact's role in this card
  createdAt DateTime   @default(now())

  card      KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  contact   Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([cardId, contactId])
  @@map("card_contacts")
}

// ─── AI Memory & Learning ──────────────────────────────────────────────────────

model MemoryItem {
  id         String   @id @default(cuid())
  tier       Int      @default(1) // 1=Explicit Facts, 2=Behavioral Rules, 3=Learned Patterns
  category   String   // Tier1: "general"|"project"|"contact" | Tier2: "communication"|"workflow"|"preferences" | Tier3: "style"|"preference"|"workflow"|"communication"
  key        String
  value      String
  scope      String?  // Tier1: scope context (e.g., project name, contact name)
  pinned     Boolean  @default(false) // Tier1: pin for high priority
  priority   String?  // Tier2: "critical"|"high"|"medium"|"low"
  confidence Float?   // Tier3: confidence score 0.0-1.0
  approved   Boolean? // Tier3: user approval status (null=pending, true=approved, false=rejected)
  source     String?  // "user" | "agent" | "system"
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("memory_items")
}

model AgentRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  rule        String   // The actual rule text
  enabled     Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("agent_rules")
}

model UserLearning {
  id          String   @id @default(cuid())
  category    String   // "style" | "preference" | "workflow" | "communication"
  observation String
  confidence  Float    @default(0.5)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_learnings")
}

// ─── Configuration ─────────────────────────────────────────────────────────────

model AgentApiKey {
  id        String   @id @default(cuid())
  provider  String   // "openai" | "anthropic"
  label     String?
  apiKey    String   // Encrypted in production
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agent_api_keys")
}
